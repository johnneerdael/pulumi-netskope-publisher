  "resources": {
    "netskope-publisher:index:AwsPublisher": {
      "isComponent": true,
      "description": "Creates one or more Netskope Private Access Publisher EC2 instances and registers them with a Netskope tenant.",
      "inputProperties": {
        "namePrefix": {
          "type": "string",
          "description": "Prefix used to derive publisher names when explicit names are not supplied."
        },
        "names": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Explicit publisher names to create."
        },
        "replicas": {
          "type": "integer",
          "description": "Number of publishers to create when names are not supplied."
        },
        "tenantUrl": {
          "type": "string",
          "description": "Netskope tenant URL used for publisher registration."
        },
        "apiToken": {
          "type": "string",
          "description": "Netskope API token used for publisher registration.",
          "secret": true
        },
        "wizardPath": {
          "type": "string",
          "description": "Netskope publisher registration wizard API path."
        },
        "tags": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "description": "Tags applied to supported provider resources."
        },
        "registrations": {
          "$ref": "#/types/netskope-publisher:index:PublisherRegistrationMap",
          "description": "Pre-created Netskope publisher registrations keyed by publisher name."
        },
        "subnetId": {
          "type": "string",
          "description": "AWS subnet ID for publisher network interfaces."
        },
        "securityGroupIds": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "AWS security group IDs attached to publisher instances."
        },
        "keyName": {
          "type": "string",
          "description": "Optional EC2 key pair name."
        },
        "instanceType": {
          "type": "string",
          "description": "EC2 instance type."
        },
        "amiId": {
          "type": "string",
          "description": "Publisher AMI ID."
        },
        "associatePublicIpAddress": {
          "type": "boolean",
          "description": "Whether to associate public IP addresses."
        },
        "iamInstanceProfile": {
          "type": "string",
          "description": "Optional IAM instance profile name."
        },
        "ebsOptimized": {
          "type": "boolean",
          "description": "Whether to enable EBS optimization."
        },
        "monitoring": {
          "type": "boolean",
          "description": "Whether to enable detailed EC2 monitoring."
        },
        "metadataOptions": {
          "$ref": "#/types/netskope-publisher:index:MetadataOptions",
          "description": "EC2 instance metadata service options."
        }
      },
      "requiredInputs": [
        "subnetId",
        "securityGroupIds"
      ],
      "properties": {
        "publisherNames": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Created publisher names."
        },
        "publishers": {
          "$ref": "#/types/netskope-publisher:index:PublisherOutputMap",
          "description": "Publisher registration and VM details keyed by name."
        }
      }
    },
