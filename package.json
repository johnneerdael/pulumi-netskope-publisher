{
  "name": "@johnneerdael/pulumi-netskope-publisher",
  "version": "0.1.0",
  "description": "Pulumi components for Netskope Private Access Publishers.",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "files": [
    "dist/src",
    "docs/_index.md",
    "docs/installation-configuration.md",
    "docs/registry-publication-checklist.md",
    "docs/registry-submission.md",
    "PulumiPlugin.yaml",
    "README.md",
    "schema.json",
    "cmd/pulumi-resource-netskope-publisher/main.go",
    "internal/provider/components.go",
    "internal/provider/provider.go",
    "internal/provider/types.go",
    "go.mod",
    "go.sum",
    "scripts/build-plugin-archives.mjs",
    "scripts/check-registry-readiness.mjs",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test \"dist/test/**/*.test.js\"",
    "clean": "rm -rf dist",
    "prepack": "npm run clean && npm run build",
    "go:test": "go test ./cmd/pulumi-resource-netskope-publisher ./internal/provider",
    "plugin:dist": "node scripts/build-plugin-archives.mjs",
    "registry:check": "node scripts/check-registry-readiness.mjs",
    "release:check": "npm ci && npm run typecheck && npm test && npm run go:test && npm run registry:check && npm run plugin:dist"
  },
  "keywords": [
    "pulumi",
    "netskope",
    "npa",
    "publisher",
    "aws",
    "azure",
    "gcp",
    "vsphere"
  ],
  "author": "John Neerdael",
  "license": "Apache-2.0",
  "dependencies": {
    "@pulumi/aws": "^6.0.0",
    "@pulumi/azure-native": "^3.18.0",
    "@pulumi/gcp": "^9.23.0",
    "@pulumi/pulumi": "^3.0.0",
    "@pulumi/vsphere": "^4.16.5"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
