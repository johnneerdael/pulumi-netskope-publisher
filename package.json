{
  "name": "@johninnl/pulumi-netskope-publisher",
  "version": "0.1.12",
  "description": "Pulumi components for Netskope Private Access Publishers.",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/johnneerdael/pulumi-netskope-publisher"
  },
  "files": [
    "dist/src",
    "docs/_index.md",
    "docs/installation-configuration.md",
    "docs/registry-pr-body.md",
    "docs/registry-publication-checklist.md",
    "docs/registry-submission.md",
    "PulumiPlugin.yaml",
    "README.md",
    "schema.json",
    "cmd/pulumi-resource-netskope-publisher/main.go",
    "internal/provider/components.go",
    "internal/provider/provider.go",
    "internal/provider/registration.go",
    "internal/provider/types.go",
    "go.mod",
    "go.sum",
    "scripts/build-plugin-archives.mjs",
    "scripts/bump-release-version.mjs",
    "scripts/check-registry-readiness.mjs",
    "scripts/generate-sdks.mjs",
    "scripts/package-sdks.mjs",
    "scripts/run-node-tests.mjs",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node scripts/run-node-tests.mjs",
    "clean": "rm -rf dist",
    "prepack": "npm run clean && npm run build",
    "go:test": "go test ./cmd/pulumi-resource-netskope-publisher ./internal/provider",
    "plugin:dist": "node scripts/build-plugin-archives.mjs",
    "sdk:gen": "node scripts/generate-sdks.mjs",
    "sdk:pack": "node scripts/package-sdks.mjs",
    "registry:check": "node scripts/check-registry-readiness.mjs",
    "release:bump": "node scripts/bump-release-version.mjs",
    "release:check": "npm ci && npm run typecheck && npm test && npm run go:test && npm run sdk:gen && npm run registry:check && npm run plugin:dist && npm run sdk:pack"
  },
  "keywords": [
    "pulumi",
    "netskope",
    "npa",
    "publisher",
    "aws",
    "azure",
    "gcp",
    "kubernetes",
    "vsphere",
    "proxmoxve",
    "proxmox"
  ],
  "author": "John Neerdael",
  "license": "Apache-2.0",
  "dependencies": {
    "@muhlba91/pulumi-proxmoxve": "^8.2.1",
    "@ovhcloud/pulumi-ovh": "^2.13.0",
    "@pierskarsenbarg/nutanix": "^0.11.0",
    "@pulumi/alicloud": "^3.102.0",
    "@pulumi/aws": "^6.0.0",
    "@pulumi/azure-native": "^3.18.0",
    "@pulumi/gcp": "^9.23.0",
    "@pulumi/hcloud": "^1.36.0",
    "@pulumi/kubernetes": "^4.31.0",
    "@pulumi/oci": "^4.11.0",
    "@pulumi/openstack": "^5.4.2",
    "@pulumi/pulumi": "^3.0.0",
    "@pulumi/vsphere": "^4.16.5",
    "@pulumiverse/esxi-native": "^1.0.0",
    "@pulumiverse/scaleway": "^1.49.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
